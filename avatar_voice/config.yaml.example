# === Hermes Voice Pipeline — Configuração ===
# Copie este arquivo para config.yaml e ajuste conforme necessário.

agent:
  base_url: "http://localhost:11434/v1"   # Ollama local
  model: "mascote"                         # modelo criado com: ollama create mascote -f Modelfile
  api_key: "ollama"                        # qualquer string para Ollama local
  temperature: 0.9
  max_tokens: 150
  history_turns: 6                         # número de turns de conversa mantidos
  history_reset_minutes: 10               # reseta histórico após X min dormindo (0 = nunca)
  timeout: 240                             # segundos — 240 para Ollama cold start, 30 para OpenAI/cloud

wake_word:
  model_path: "../wake_word_models/central.onnx"  # trocar para avatar.onnx quando treinado
  threshold: 0.5
  cooldown_seconds: 2.0
  vad_rms_min: 50
  # fallback_mode: "keyboard"  # descomente para testar sem modelo (pressione ENTER)

tts:
  piper_binary: "piper"                    # ou caminho absoluto (ex: C:/piper/piper.exe)
  model_path: "../piper_models/nanda_ptbr.onnx"
  length_scale: 0.95                       # velocidade (menor = mais rápido)
  noise_scale: 0.667                       # variação de prosódia
  noise_w: 0.8                             # variação de duração de fonemas
  pitch_semitones: 0                       # ajuste de pitch em semitons (requer sox)
  volume: 1.0                              # multiplicador de volume (0.0 a 1.0+)
  chunk_max_chars: 80                      # tamanho máximo de chunk de resposta

stt:
  model: "base"                            # tiny | base | small | medium | large-v3
  language: "pt"                           # código de idioma para transcrição
  device: "auto"                           # cpu | cuda | auto
  silence_threshold_rms: 200              # RMS abaixo deste = silêncio (0-32767)
  silence_duration_seconds: 1.5          # segundos de silêncio para parar gravação
  followup_timeout_seconds: 5.0          # timeout para follow-up / ouvindo inicial
  max_session_seconds: 20.0              # duração máxima de uma sessão de escuta

audio:
  input_device: null                       # null = dispositivo padrão do sistema
  output_device: null                      # null = dispositivo padrão do sistema
  sample_rate: 16000                       # taxa de amostragem para STT (não alterar)

logging:
  level: "INFO"                            # DEBUG | INFO | WARNING
  show_scores: false                       # exibe score da wake word no log (DEBUG)

# === Providers personalizados ===
# Adicione quantos quiser. Cada um é um backend OpenAI-compatible.
# Na GUI, use os botões + e - para gerenciar. Na CLI: --provider <nome>
# Env var override: <NOME_MAIÚSCULO>_API_KEY (ex: MEUBOT_API_KEY)
# providers:
#   meubot:
#     model: "meu-modelo"
#     api_key: ""
#     base_url: "http://meu-server:8080/v1"
#     timeout: 30
